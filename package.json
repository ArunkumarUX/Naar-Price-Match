{
  "name": "naar-price-monitor",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "start": "node --import tsx/esm src/api/server.ts",
    "worker": "node --import tsx/esm src/jobs/worker.ts",
    "worker:dev": "tsx watch src/jobs/worker.ts",
    "build": "tsc",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@prisma/client": "^6.0.0",
    "@sendgrid/mail": "^8.1.0",
    "@xenova/transformers": "^2.17.0",
    "axios": "^1.7.0",
    "bullmq": "^5.12.0",
    "fastify": "^5.0.0",
    "fuse.js": "^7.0.0",
    "ioredis": "^5.3.0",
    "playwright": "^1.58.0",
    "zod": "^3.23.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.4.0"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
