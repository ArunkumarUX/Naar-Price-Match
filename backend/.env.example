# Naar shop catalog (source of truth)
NAAR_SHOP_URL=https://naar.io/shop
NAAR_BASE_URL=https://naar.io
# NAAR_CATALOG_API=https://api.naar.io/products
# Set your Anthropic key and enable production to disable demo data.
ANTHROPIC_API_KEY=sk-ant-...
PRODUCTION_MODE=true
CLAUDE_MODEL=claude-sonnet-4-20250514
USE_CLAUDE=true
DEMO_MODE=false

# ── Database (optional — SQLite used in demo) ─────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/naar_monitor
REDIS_URL=redis://localhost:6379/0

# ── Marketplace scraping (recommended for best results) ───────────────
BRIGHTDATA_PROXY=
SCRAPERAPI_KEY=

# ── Alerts ────────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=pricing@naar.io

# ── Matching ────────────────────────────────────────────────────────
MIN_MATCH_CONFIDENCE=0.75
