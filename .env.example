NODE_ENV=development
PORT=8000
HOST=0.0.0.0

DATABASE_URL=postgresql://user:password@localhost:5432/naar_monitor
REDIS_URL=redis://localhost:6379

EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
USE_EMBEDDINGS=false
MIN_MATCH_CONFIDENCE=0.75
MAX_PRICE_DEVIATION_PCT=5
CRITICAL_DEVIATION_PCT=20
DEMO_MODE=false

NAAR_BASE_URL=https://naar.io
NAAR_SHOP_URL=https://naar.io/shop
# Live commerce catalog (primary source of truth)
NAAR_CATALOG_API=https://naar.io/api/v1/ecommerce/products
# Optional bearer token if the catalog API requires auth
NAAR_CATALOG_API_KEY=

BRIGHTDATA_PROXY=
SCRAPERAPI_KEY=

SENDGRID_API_KEY=
ALERT_EMAIL_FROM=alerts@naar.io
ALERT_EMAIL_TO=pricing@naar.io
SLACK_WEBHOOK_URL=

CORS_ORIGIN=http://localhost:3000
